{
  "mcpServers": {
    "kanban": {
      "url": "https://kanban.hackedyour.info/mcp/http/api-key/mcp",
      "headers": {
        "Authorization": "Bearer ${KANBAN_API_KEY}",
        "X-Workspace-slug": "gemwebui"
      }
    }
  },
  "general": {
    "plan": {
      "directory": "plans"
    }
  },
  "ui": {
    "inlineThinkingMode": "full"
  },
  "agents": {
    "overrides": {
      "quality_control_agent": {
        "enabled": false
      },
      "kanban_executor": {
        "enabled": false
      }
    }
  },
  "hooks": {
    "AfterTool": [
      {
        "matcher": "update_work_item",
        "hooks": [
          {
            "name": "validate-ticket",
            "type": "command",
            "command": "./.gemini/hooks/validate-ticket.sh",
            "description": "Trigger validation pipeline when ticket moves to Needs Validation"
          }
        ]
      }
    ]
  }
}
