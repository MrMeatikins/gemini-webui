#!/bin/bash
set -e

# Pre-commit hook to validate tests, increment version, and perform AI QA

echo "Running pre-commit hook..."

TICKET_FILE="/tmp/gemini-webui-ticket.txt"
RESULTS_FILE="/tmp/gemini-webui-unit-test-results.txt"
REALITY_FILE="/tmp/gemini-webui-reality-results.txt"

# 0. Verify ticket file exists
if [ ! -f "$TICKET_FILE" ]; then
    echo "Commit rejected: $TICKET_FILE not found."
    echo "Please create a Kanban ticket and save its identifier to $TICKET_FILE before committing."
    exit 1
fi

# Check if file is not empty
if [ ! -s "$TICKET_FILE" ]; then
    echo "Commit rejected: $TICKET_FILE is empty."
    echo "Please save the Kanban ticket identifier to $TICKET_FILE before committing."
    exit 1
fi

TICKET_ID=$(cat "$TICKET_FILE")

echo "Ticket identifier found: $TICKET_ID"

# 1. Run unit tests
echo "Running unit tests..."
set +e
source .venv/bin/activate
PYTHONPATH=. pytest tests/ > "$RESULTS_FILE" 2>&1
PYTEST_EXIT_CODE=$?
set -e

# 2. Check for skipped or failed tests
if grep -qE "([0-9]+ failed|[0-9]+ skipped)" "$RESULTS_FILE" || [ $PYTEST_EXIT_CODE -ne 0 ]; then
    echo "Commit rejected: Unit tests failed or were skipped."
    cat "$RESULTS_FILE"
    exit 1
fi

echo "Unit tests passed. Triggering reality-checker agent..."

# 3. Call reality-checker
# We use gemini CLI to invoke the agent. We pipe the test results and pass the prompt.
cat "$RESULTS_FILE" | gemini -y -p "@reality-checker Please examine the Kanban ticket with identifier ${TICKET_ID} via MCP and the provided unit test results from stdin. Please validate quality and completeness. Reply \`NEEDS WORK\` and an explanation if further work is required. We expect top notch results." > "$REALITY_FILE" 2>&1

# 4. Check reality results
if grep -q "NEEDS WORK" "$REALITY_FILE"; then
    echo "Commit rejected: reality-checker determined that the work needs improvement."
    echo "--------------------------------------------------------"
    cat "$REALITY_FILE"
    echo "--------------------------------------------------------"
    exit 1
fi

echo "reality-checker approved the commit!"

# Finally, increment the version
./scripts/increment_version.sh
